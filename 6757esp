function SkeletonESP:createSkeleton(player)
    local skeleton = {}
    skeleton.lines = {}
    skeleton.visible = true
    return skeleton
end

function SkeletonESP:updateSkeleton(player)
    if not Config.ESP.Drawing.Skeleton.Enabled then
        if self.skeletonCache[player] then
            for _, line in pairs(self.skeletonCache[player].lines) do
                line.Visible = false
            end
        end
        return
    end
    
    local character = player.Character
    local humanoid = character and character:FindFirstChild("Humanoid")
    
    if not character or not humanoid or not humanoid.RootPart then
        if self.skeletonCache[player] then
            for _, line in pairs(self.skeletonCache[player].lines) do
                line.Visible = false
            end
        end
        return
    end
    
    if not self.skeletonCache[player] then
        self.skeletonCache[player] = self:createSkeleton(player)
    end
    
    local skeleton = self.skeletonCache[player]
    local connections = bodyConnections[humanoid.RigType.Name] or bodyConnections.R15
    local currentLines = {}
    
    local skeletonColor = Config.ESP.Drawing.Skeleton.Color
    if Config.ESP.Rainbow then
        skeletonColor = getRainbowColor(0.2) 
    end
    
    for _, connection in ipairs(connections) do
        local partA = character:FindFirstChild(connection[1])
        local partB = character:FindFirstChild(connection[2])
        
        if partA and partB then
            local lineKey = connection[1] .. "-" .. connection[2]
            local line = skeleton.lines[lineKey]
            
            if not line then
                line = self:createLine({
                    Thickness = Config.ESP.Drawing.Skeleton.Thickness,
                    Color = skeletonColor,
                    Transparency = Config.ESP.Drawing.Skeleton.Transparency,
                    Visible = true
                })
                skeleton.lines[lineKey] = line
            end
            
            local posA, onScreenA = game:GetService("Workspace").CurrentCamera:WorldToViewportPoint(partA.Position)
            local posB, onScreenB = game:GetService("Workspace").CurrentCamera:WorldToViewportPoint(partB.Position)
            
            if onScreenA and onScreenB then
                if Config.ESP.Drawing.Skeleton.DynamicColor or Config.ESP.Drawing.Skeleton.DynamicThickness then
                    local distance = (posA - posB).Magnitude
                    
                    if Config.ESP.Drawing.Skeleton.DynamicThickness then
                        local thickness = math.clamp(3 - (distance / 300), 1.5, 3)
                        line.Thickness = thickness
                    else
                        line.Thickness = Config.ESP.Drawing.Skeleton.Thickness
                    end
                    
                    if Config.ESP.Drawing.Skeleton.DynamicColor then
                        local brightness = math.clamp(1 - (distance / 500), 0.5, 1)
                        local dynamicColor = Color3.new(
                            skeletonColor.R * brightness,
                            skeletonColor.G * brightness,
                            skeletonColor.B * brightness
                        )
                        line.Color = dynamicColor
                    else
                        line.Color = skeletonColor
                    end
                else
                    line.Thickness = Config.ESP.Drawing.Skeleton.Thickness
                    line.Color = skeletonColor
                end
                
                line.From = Vector2.new(posA.X, posA.Y)
                line.To = Vector2.new(posB.X, posB.Y)
                line.Transparency = Config.ESP.Drawing.Skeleton.Transparency
                line.Visible = true
                currentLines[lineKey] = true
            else
                line.Visible = false
            end
        end
    end
    
    for lineKey, line in pairs(skeleton.lines) do
        if not currentLines[lineKey] then
            line.Visible = false
        end
    end
end

function SkeletonESP:removeSkeleton(player)
    local skeleton = self.skeletonCache[player]
    if skeleton then
        for _, line in pairs(skeleton.lines) do
            line:Remove()
        end
        self.skeletonCache[player] = nil
    end
end

function SkeletonESP:removeAll()
    for player, skeleton in pairs(self.skeletonCache) do
        for _, line in pairs(skeleton.lines) do
            line:Remove()
        end
    end
    self.skeletonCache = {}
end

